{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import base64; print(base64.b64decode('').decode('utf-8'))\"",
            "timeout": 5,
            "statusMessage": "Loading Agent Config Kit",
            "commandWindows": "py -3 -c \"import base64; print(base64.b64decode('').decode('utf-8'))\""
          }
        ]
      }
    ]
  },
  "description": "Agent Config Kit safe startup reminder."
}
